FLASK_SECRET_KEY=change-me-to-a-long-random-string
ADMIN_PASSWORD=change-me
DATABASE_PATH=/app/data/praulitis.db
UPLOAD_PATH=/app/app/static/uploads
FLASK_PORT=5002

# AWS S3 — optional. If set, uploads go to S3 instead of local disk.
# AWS credentials are picked up from ~/.aws/credentials or IAM role (no keys needed on EC2/ECS).
# On Raspberry Pi, create an IAM user with S3 access and set these:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=praulits-media
AWS_S3_REGION=eu-north-1
AWS_CLOUDFRONT_URL=https://xxxx.cloudfront.net
